# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real API keys.

# ===== LLM Providers (free tier) =====
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
OPENROUTER_VISION_MODEL_2=google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ===== Pipeline config =====
MAX_CORRECTION_ITERATIONS=3
SSIM_THRESHOLD=0.92
PDF_RENDER_DPI=250

# ===== Render service (Node) =====
RENDER_SERVICE_URL=http://localhost:4000/render
RENDER_SERVICE_PORT=4000

# ===== Backend (FastAPI) =====
BACKEND_PORT=8000
TEMP_UPLOAD_DIR=./tmp/uploads
OUTPUT_DIR=./tmp/outputs

# ===== Console logging only (no file/db) =====
LOG_LEVEL=INFO
